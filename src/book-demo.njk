    {% else %}
    <div style="border:1px dashed #1FA049;border-radius:8px;background:#e6f1f6;padding:28px;text-align:center;">
      <div style="font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#005a7a;margin-bottom:8px;">Scheduler</div>
      <p style="font-size:14px;color:#59595C;line-height:1.6;margin:0;">The HubSpot Meetings scheduler embeds here. It is connected during launch setup (Phase&nbsp;4). Until then, session requests route to <a href="mailto:info@workinflow.co.za" style="color:#0075A0;">info@workinflow.co.za</a>.</p>
    </div>
